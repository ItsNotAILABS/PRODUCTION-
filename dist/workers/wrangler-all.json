{
  "workers": [
    {
      "name": "organism-router",
      "main": "dist/workers/organism-router.js",
      "compatibility_date": "2025-01-01",
      "workers_dev": false,
      "routes": [
        {
          "pattern": "/*",
          "zone_name": "sovereign-organism.com"
        }
      ],
      "vars": {
        "WORKER_TYPE": "router",
        "ORGANISM_ID": "sovereign",
        "PHI": "1.618033988749895"
      },
      "limits": {
        "cpu_ms": 10
      }
    },
    {
      "name": "organism-api-gw",
