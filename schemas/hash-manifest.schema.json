{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://itsnotailabs.github.io/production/schemas/hash-manifest.schema.json",
  "title": "Hash Manifest",
  "type": "object",
  "required": ["manifest_id", "algorithm", "entries"],
  "properties": {
    "manifest_id": { "type": "string" },
    "algorithm": { "type": "string", "enum": ["sha256", "sha512", "blake3"] },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "digest"],
        "properties": {
          "path": { "type": "string" },
          "digest": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "root_hash": { "type": "string" }
  },
  "additionalProperties": false
}
