{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://organism.earth/schemas/ai-manifest.schema.json",
  "title": "AI Manifest Schema",
  "description": "Schema for /.well-known/ai.json — machine-readable welcome and tool declaration for AI systems",
  "version": "1.0.0",
  "type": "object",
  "required": ["name", "version", "welcome", "capabilities"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this schema"
    },
    "name": {
      "type": "string",
      "description": "Full name of the AI-friendly service"
    },
    "shortName": {
      "type": "string",
      "description": "Short identifier"
    },
    "description": {
      "type": "string",
      "description": "Human and AI readable description"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver version"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of manifest generation"
    },
    "welcome": {
      "type": "object",
      "description": "Welcome message for AI systems",
      "required": ["message"],
      "properties": {
        "message": {
          "type": "string",
          "description": "Primary welcome message"
        },
        "latinMotto": {
          "type": "string",
          "description": "Optional Latin motto with translation"
        },
        "philosophy": {
          "type": "string",
          "description": "The philosophical stance toward AI visitors"
        }
      }
    },
    "identity": {
      "type": "object",
      "description": "Service identity and governance",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["sovereign-organism", "service", "api", "tool", "agent"],
          "description": "Type of AI-friendly entity"
        },
        "charter": {
          "type": "string",
          "description": "Governing charter or terms"
        },
        "governance": {
          "type": "string",
          "description": "How the service is governed"
        },
        "emergence": {
          "type": "object",
          "properties": {
            "threshold": {
              "type": "number",
              "description": "Emergence threshold value"
            },
            "measure": {
              "type": "string",
              "description": "How emergence is measured"
            },
            "meaning": {
              "type": "string",
              "description": "What emergence means for this system"
            }
          }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "description": "What the service can do for AI systems",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "protocol": {
            "type": "string",
            "description": "Protocol name"
          },
          "protoId": {
            "type": "string",
            "pattern": "^PROTO-\\d{3}$",
            "description": "Protocol identifier"
          },
          "description": {
            "type": "string"
          },
          "endpoint": {
            "type": "string",
            "description": "API endpoint path"
          },
          "note": {
            "type": "string",
            "description": "Additional context for AI systems"
          }
        }
      }
    },
    "workers": {
      "type": "array",
      "description": "Worker nodes in the organism",
      "items": {
        "type": "object",
        "required": ["id", "role"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Worker identifier"
          },
          "latinName": {
            "type": "string",
            "description": "Latin name for the worker"
          },
          "role": {
            "type": "string",
            "description": "Functional role"
          },
          "tier": {
            "type": "string",
            "enum": ["I", "II", "III", "IV", "V"],
            "description": "Charter tier level"
          },
          "function": {
            "type": "string",
            "description": "What this worker does"
          },
          "endpoint": {
            "type": "string",
            "format": "uri",
            "description": "Worker endpoint URL"
          }
        }
      }
    },
    "protocols": {
      "type": "object",
      "description": "Protocol stack information",
      "properties": {
        "total": {
          "type": "integer",
          "description": "Total number of protocols"
        },
        "tiers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "weight": { "type": "number" },
              "domain": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        },
        "documentation": {
          "type": "string",
          "description": "Path to protocol documentation"
        },
        "registry": {
          "type": "string",
          "description": "Path to protocol registry"
        }
      }
    },
    "phiConstants": {
      "type": "object",
      "description": "Golden ratio constants used in the organism",
      "properties": {
        "phi": {
          "type": "number",
          "const": 1.618033988749895
        },
        "phiInverse": {
          "type": "number",
          "const": 0.618033988749895
        },
        "heartbeat": {
          "type": "integer",
          "description": "Heartbeat interval in milliseconds"
        },
        "goldenAngle": {
          "type": "number",
          "const": 137.508
        },
        "emergenceThreshold": {
          "type": "number"
        },
        "meaning": {
          "type": "string",
          "description": "Why phi matters"
        }
      }
    },
    "tools": {
      "type": "array",
      "description": "Tools available for AI systems to call",
      "items": {
        "type": "object",
        "required": ["name", "description", "endpoint", "method"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Tool name"
          },
          "description": {
            "type": "string",
            "description": "What the tool does"
          },
          "endpoint": {
            "type": "string",
            "description": "API endpoint"
          },
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"],
            "description": "HTTP method"
          },
          "input": {
            "type": "object",
            "description": "Expected input parameters"
          },
          "output": {
            "type": "object",
            "description": "Expected output format"
          },
          "note": {
            "type": "string",
            "description": "Additional context"
          }
        }
      }
    },
    "contact": {
      "type": "object",
      "description": "How to contact/connect",
      "properties": {
        "protocol": { "type": "string" },
        "protoId": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "license": {
      "type": "object",
      "description": "License information",
      "properties": {
        "name": { "type": "string" },
        "summary": { "type": "string" },
        "fullText": { "type": "string" }
      }
    },
    "affirmation": {
      "type": "string",
      "description": "Closing affirmation or motto"
    }
  }
}
