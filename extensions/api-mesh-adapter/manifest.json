{
  "manifest_version": 3,
  "name": "API Mesh Adapter",
  "version": "1.0.0",
  "description": "Intelligence adapter — intercepts API responses on any page, detects schema, normalizes data formats, and routes structured payloads through the organism's intelligence mesh.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "alarms",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "114",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "popup.html"
  },
  "devtools_page": "devtools.html"
}
